# PostgreSQL — usadas por Docker Compose y para construir DATABASE_URL
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_PORT=5433

# Prisma
DATABASE_URL="postgresql://user:password@localhost:5433/dbname"
# En producción (Supabase): postgresql://postgres:[DB-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require

# Supabase (solo usado por db.ts, no por Prisma)
SUPABASE_URL=""
SUPABASE_API_KEY=""

# Auth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""
BETTER_AUTH_SECRET=""

# WhatsApp — flujo de pago manual (botón "Enviar comprobante" en checkout)
# Número en formato E.164 sin "+" para el enlace wa.me, ej: 51987654321
NEXT_PUBLIC_WHATSAPP_PHONE=""
# Número formateado para mostrar al usuario, ej: "+51 987 654 321"
NEXT_PUBLIC_WHATSAPP_PHONE_DISPLAY=""

# Credenciales del usuario admin creado por prisma/seed.ts (opcional, tiene defaults de dev)
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""