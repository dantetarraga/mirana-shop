generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}
datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  CUSTOMER
  ADMIN
}

enum ProductStatus {
  AVAILABLE
  PREORDER
  SOLD_OUT
  COMING_SOON
  ARCHIVED
}

enum OrderStatus {
  PENDING
  AWAITING_PROOF
  PAID
  PREPARING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  UNPAID
  PROCESSING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CULQI_CARD
  CULQI_YAPE
  WHATSAPP_TRANSFER
}

enum InventoryMovementType {
  PURCHASE
  SALE
  ADJUSTMENT
  RETURN
}

enum InventoryStockType {
  NORMAL
  PREORDER
}

enum PreorderStatus {
  PENDING    // Reserva creada, pendiente de depósito
  CONFIRMED  // Depósito recibido y confirmado
  READY      // Producto en stock, listo para cobrar saldo
  CONVERTED  // Convertida en Order final
  CANCELLED
  EXPIRED
}

// ---------------------------------------------------------------------------
// Auth.js / NextAuth models
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  name          String?
  image         String?
  role          Role      @default(CUSTOMER)

  termsAcceptedAt DateTime? // Fecha en que aceptó los Términos y Condiciones
  termsVersion    String?   // Versión del documento aceptado, e.g. "v1.0"

  profile  Profile?
  accounts  Account[]
  sessions  Session[]
  orders    Order[]
  preorders Preorder[]
  addresses UserAddress[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([role])
  @@index([deletedAt])
}

model Profile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  phone     String?
  dni       String?
  hasKids   Boolean @default(false)
  kidsCount Int?

  updatedAt DateTime @updatedAt
}

model UserAddress {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  label     String  @default("Casa") // "Casa", "Trabajo", "Otro"
  fullName  String
  phone     String
  address   String
  district  String
  city      String  @default("Lima")
  reference String?
  isDefault Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Catalog
// ---------------------------------------------------------------------------

model Category {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  parentId    String?
  description String? @db.Text
  imageUrl    String?

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  @@index([slug])
}

model Brand {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  tagline     String?           /// Subtítulo corto para el carrusel: "TAMASHII NATIONS", "ARTFX SERIES"
  description String? @db.Text
  imageUrl    String?

  products Product[]

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  @@index([slug])
}

model Product {
  id             String        @id @default(cuid())
  sku            String        @unique
  slug           String        @unique
  name           String
  description    String        @db.Text
  price          Decimal       @db.Decimal(10, 2)
  compareAtPrice Decimal?      @db.Decimal(10, 2)
  salePrice      Decimal?      @db.Decimal(10, 2)
  currency       String        @default("PEN")
  status         ProductStatus @default(AVAILABLE)
  featured       Boolean       @default(false)
  categoryId     String
  brandId        String

  category    Category           @relation(fields: [categoryId], references: [id])
  brand       Brand              @relation(fields: [brandId], references: [id])
  images      ProductImage[]
  inventory   ProductInventory?
  orderItems  OrderItem[]
  movements   InventoryMovement[]
  preorders   Preorder[]
  collections ProductCollection[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([status, featured])
  @@index([categoryId])
  @@index([brandId])
  @@index([slug])
  @@index([deletedAt])
}

model ProductInventory {
  id        String  @id @default(cuid())
  productId String  @unique
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  availableStock    Int  @default(0)
  reservedStock     Int  @default(0)
  preorderedStock   Int  @default(0)
  lowStockThreshold Int?
  /// Optimistic locking — se incrementa en cada actualización de stock
  version           Int  @default(0)

  updatedAt DateTime @updatedAt

  @@index([availableStock])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  position  Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, position])
}

// ---------------------------------------------------------------------------
// Orders
// ---------------------------------------------------------------------------

model Order {
  id            String        @id @default(cuid())
  /// Código legible para el cliente, ej: MIR-2024-0001
  code          String        @unique
  userId        String?
  user          User?         @relation(fields: [userId], references: [id])
  guestEmail    String?
  status        OrderStatus   @default(PENDING)
  paymentStatus PaymentStatus @default(UNPAID)
  paymentMethod PaymentMethod

  subtotal     Decimal @db.Decimal(10, 2)
  shippingCost Decimal @default(0) @db.Decimal(10, 2)
  total        Decimal @db.Decimal(10, 2)
  currency     String  @default("PEN")

  items    OrderItem[]
  payment  Payment?
  shipping ShippingAddress?
  movements InventoryMovement[]
  preorder  Preorder?

  notes String? @db.Text

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  paidAt      DateTime?
  cancelledAt DateTime?

  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String

  quantity    Int
  unitPrice   Decimal @db.Decimal(10, 2)
  /// Snapshot del nombre al momento de la compra
  productName String
  /// Snapshot del SKU al momento de la compra
  productSku  String

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id      String @id @default(cuid())
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  method   PaymentMethod
  status   PaymentStatus @default(UNPAID)
  amount   Decimal       @db.Decimal(10, 2)
  currency String        @default("PEN")

  culqiOrderId  String? @unique
  culqiChargeId String? @unique
  culqiEventId  String? @unique
  culqiQrUrl    String?
  culqiPeUrl    String?
  proofUrl      String?
  rawResponse   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShippingAddress {
  id      String @id @default(cuid())
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  fullName  String
  phone     String
  address   String
  district  String
  city      String @default("Lima")
  reference String?
}

// ---------------------------------------------------------------------------
// Inventory
// ---------------------------------------------------------------------------

model InventoryMovement {
  id        String @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id])
  orderId   String?
  order     Order?  @relation(fields: [orderId], references: [id])

  type         InventoryMovementType
  stockType    InventoryStockType    @default(NORMAL)
  quantity     Int
  balanceAfter Int
  reason       String?
  /// ID del usuario admin que generó el movimiento manual, si aplica
  createdById  String?

  createdAt DateTime @default(now())

  @@index([productId, createdAt])
  @@index([type])
  @@index([orderId])
}

// ---------------------------------------------------------------------------
// Preorders
// ---------------------------------------------------------------------------

model Preorder {
  id         String  @id @default(cuid())
  /// Código legible para el cliente, ej: PRE-2025-0001
  code       String  @unique
  userId     String?
  user       User?   @relation(fields: [userId], references: [id])
  guestEmail String?
  productId  String
  product    Product @relation(fields: [productId], references: [id])

  quantity        Int
  unitPrice       Decimal @db.Decimal(10, 2)
  depositAmount   Decimal @db.Decimal(10, 2)
  remainingAmount Decimal @db.Decimal(10, 2)
  currency        String  @default("PEN")

  status           PreorderStatus @default(PENDING)
  estimatedArrival DateTime?
  /// Si no paga el depósito en X días, la reserva expira
  expiresAt        DateTime?

  /// Pago del depósito (puede ser transferencia o Culqi)
  depositStatus        PaymentStatus  @default(UNPAID)
  depositMethod        PaymentMethod?
  depositPaidAt        DateTime?
  depositProofUrl      String?
  /// Idempotencia Culqi para el depósito
  depositCulqiChargeId String?        @unique

  /// Cuando la reserva se convierte en pedido final
  orderId String? @unique
  order   Order?  @relation(fields: [orderId], references: [id])

  notes String? @db.Text

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  confirmedAt DateTime?
  cancelledAt DateTime?
  convertedAt DateTime?

  @@index([userId])
  @@index([productId])
  @@index([status])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Payments — Idempotency
// ---------------------------------------------------------------------------

/// Garantiza que un pago no se procese dos veces aunque el cliente reintente.
/// El frontend genera un UUID por intento de pago y lo envía como header X-Idempotency-Key.
model IdempotencyKey {
  id       String  @id @default(cuid())
  /// UUID generado por el cliente — clave de deduplicación
  key      String  @unique
  userId   String?
  /// Endpoint o acción que se está protegiendo, ej: "checkout", "preorder.deposit"
  endpoint String

  /// Hash del body de la request — detecta reutilización incorrecta de la misma key con distinto payload
  requestHash String?

  /// Resultado cacheado de la operación
  statusCode Int?
  response   Json?

  /// lockedAt: procesando. resolvedAt: completado. Ambos null: nueva.
  lockedAt   DateTime?
  resolvedAt DateTime?

  /// Después de esta fecha la key puede reutilizarse (recomendado: 24h)
  expiresAt DateTime

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ---------------------------------------------------------------------------
// Collections
// ---------------------------------------------------------------------------

model Collection {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  description String? @db.Text
  imageUrl    String?
  active      Boolean @default(true)

  products ProductCollection[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([slug])
  @@index([active])
}

model ProductCollection {
  productId    String
  collectionId String

  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([productId, collectionId])
  @@index([collectionId])
}

// ---------------------------------------------------------------------------
// Promotions
// ---------------------------------------------------------------------------

enum PromotionType {
  FREE_SHIPPING
  FIXED_DISCOUNT
  PERCENT_DISCOUNT
}

model Promotion {
  id          String        @id @default(cuid())
  name        String
  description String?       @db.Text
  type        PromotionType
  active      Boolean       @default(true)

  /// Monto mínimo de compra (en PEN) para activar la promoción
  minAmount       Decimal?  @db.Decimal(10, 2)
  /// Descuento fijo en soles (para FIXED_DISCOUNT)
  discountAmount  Decimal?  @db.Decimal(10, 2)
  /// Porcentaje de descuento 0-100 (para PERCENT_DISCOUNT)
  discountPercent Decimal?  @db.Decimal(5, 2)

  startsAt DateTime?
  endsAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, active])
}

// ---------------------------------------------------------------------------
// Marketing
// ---------------------------------------------------------------------------

model Banner {
  id       String  @id @default(cuid())
  title    String
  subtitle String?
  imageUrl String
  ctaLabel String?
  ctaHref  String?
  position Int     @default(0)
  active   Boolean @default(true)
  startsAt DateTime?
  endsAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, position])
}
