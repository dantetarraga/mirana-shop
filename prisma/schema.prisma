generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  CUSTOMER
  ADMIN
}

enum ProductStatus {
  AVAILABLE
  PREORDER
  SOLD_OUT
  COMING_SOON
  ARCHIVED
}

enum OrderStatus {
  PENDING
  AWAITING_PROOF
  PAID
  PREPARING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  UNPAID
  PROCESSING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  WHATSAPP_TRANSFER
}

enum InventoryMovementType {
  PURCHASE
  SALE
  ADJUSTMENT
  RETURN
}

enum InventoryStockType {
  NORMAL
  PREORDER
}

enum PreorderStatus {
  PENDING // Reserva creada, pendiente de depósito
  CONFIRMED // Depósito recibido y confirmado
  READY // Producto en stock, listo para cobrar saldo
  CONVERTED // Convertida en Order final
  CANCELLED
  EXPIRED
}

// ---------------------------------------------------------------------------
// Auth.js / NextAuth models
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  name          String?
  image         String?
  role          Role      @default(CUSTOMER)

  termsAcceptedAt DateTime? // Fecha en que aceptó los Términos y Condiciones
  termsVersion    String? // Versión del documento aceptado, e.g. "v1.0"

  profile   Profile?
  accounts  Account[]
  sessions  Session[]
  orders    Order[]
  preorders Preorder[]
  addresses UserAddress[]
  cart      Cart?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([role])
  @@index([deletedAt])
}

model Profile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  phone     String?
  dni       String?
  hasKids   Boolean @default(false)
  kidsCount Int?

  updatedAt DateTime @updatedAt
}

model UserAddress {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  label     String  @default("Casa") // "Casa", "Trabajo", "Otro"
  fullName  String
  phone     String
  address   String
  district  String
  city      String  @default("Lima")
  reference String?
  isDefault Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Catalog
// ---------------------------------------------------------------------------

model Category {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  parentId    String?
  description String? @db.Text
  imageUrl    String?

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  @@index([slug])
}

model Brand {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  tagline     String? /// Subtítulo corto para el carrusel: "TAMASHII NATIONS", "ARTFX SERIES"
  description String? @db.Text
  imageUrl    String?

  products Product[]

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  @@index([slug])
}

model Product {
  id          String        @id @default(cuid())
  sku         String        @unique
  slug        String        @unique
  name        String
  description String        @db.Text
  price       Decimal       @db.Decimal(10, 2)
  salePrice   Decimal?      @db.Decimal(10, 2)
  currency    String        @default("PEN")
  status      ProductStatus @default(AVAILABLE)
  featured    Boolean       @default(false)
  categoryId  String
  brandId     String

  category    Category            @relation(fields: [categoryId], references: [id])
  brand       Brand               @relation(fields: [brandId], references: [id])
  images      ProductImage[]
  inventory   ProductInventory?
  orderItems  OrderItem[]
  cartItems   CartItem[]
  movements   InventoryMovement[]
  preorders   Preorder[]
  collections ProductCollection[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([status, featured])
  @@index([categoryId])
  @@index([brandId])
  @@index([slug])
  @@index([deletedAt])
}

model ProductInventory {
  id        String  @id @default(cuid())
  productId String  @unique
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  availableStock    Int  @default(0)
  reservedStock     Int  @default(0)
  preorderedStock   Int  @default(0)
  lowStockThreshold Int?
  /// Optimistic locking — se incrementa en cada actualización de stock
  version           Int  @default(0)

  updatedAt DateTime @updatedAt

  @@index([availableStock])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  position  Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, position])
}

// ---------------------------------------------------------------------------
// Cart — persistido en servidor, ligado a una cookie de sesión anónima
// (`sessionId`). Si el visitante inicia sesión, su carrito anónimo se
// fusiona con el carrito de su cuenta (`userId`) y se descarta el anónimo.
// ---------------------------------------------------------------------------

model Cart {
  id        String  @id @default(cuid())
  // Carrito anónimo: sessionId set, userId null. Carrito de cuenta: userId
  // set, sessionId null — nunca ambos a la vez (ver mergeAnonymousCartIntoUser),
  // así un dispositivo compartido no hereda el carrito de otra cuenta tras logout.
  sessionId String? @unique
  userId    String? @unique
  user      User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  items CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int     @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId])
  @@index([productId])
}

// ---------------------------------------------------------------------------
// Orders
// ---------------------------------------------------------------------------

model Order {
  id            String        @id @default(cuid())
  /// Código legible para el cliente, ej: MIR-2024-0001
  code          String        @unique
  userId        String?
  user          User?         @relation(fields: [userId], references: [id])
  guestEmail    String?
  status        OrderStatus   @default(PENDING)
  paymentStatus PaymentStatus @default(UNPAID)
  paymentMethod PaymentMethod

  subtotal      Decimal @db.Decimal(10, 2)
  shippingCost  Decimal @default(0) @db.Decimal(10, 2)
  /// Descuento aplicado por promociones activas al momento de la compra
  discountTotal Decimal @default(0) @db.Decimal(10, 2)
  total         Decimal @db.Decimal(10, 2)
  currency      String  @default("PEN")

  items     OrderItem[]
  payment   Payment?
  shipping  ShippingAddress?
  movements InventoryMovement[]
  preorder  Preorder?

  notes String? @db.Text

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  paidAt      DateTime?
  cancelledAt DateTime?

  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  productId String

  quantity    Int
  unitPrice   Decimal @db.Decimal(10, 2)
  /// Snapshot del nombre al momento de la compra
  productName String
  /// Snapshot del SKU al momento de la compra
  productSku  String

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id      String @id @default(cuid())
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  method   PaymentMethod
  status   PaymentStatus @default(UNPAID)
  amount   Decimal       @db.Decimal(10, 2)
  currency String        @default("PEN")

  /// URL del comprobante de pago enviado por el cliente (WhatsApp)
  proofUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShippingAddress {
  id      String @id @default(cuid())
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  fullName  String
  phone     String
  address   String
  district  String
  city      String  @default("Lima")
  reference String?
}

// ---------------------------------------------------------------------------
// Inventory
// ---------------------------------------------------------------------------

model InventoryMovement {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id])
  orderId   String?
  order     Order?  @relation(fields: [orderId], references: [id])

  type         InventoryMovementType
  stockType    InventoryStockType    @default(NORMAL)
  quantity     Int
  balanceAfter Int
  reason       String?
  /// ID del usuario admin que generó el movimiento manual, si aplica
  createdById  String?

  createdAt DateTime @default(now())

  @@index([productId, createdAt])
  @@index([type])
  @@index([orderId])
}

// ---------------------------------------------------------------------------
// Preorders
// ---------------------------------------------------------------------------

model Preorder {
  id         String  @id @default(cuid())
  /// Código legible para el cliente, ej: PRE-2025-0001
  code       String  @unique
  userId     String?
  user       User?   @relation(fields: [userId], references: [id])
  guestEmail String?
  productId  String
  product    Product @relation(fields: [productId], references: [id])

  quantity        Int
  unitPrice       Decimal @db.Decimal(10, 2)
  depositAmount   Decimal @db.Decimal(10, 2)
  remainingAmount Decimal @db.Decimal(10, 2)
  currency        String  @default("PEN")

  status           PreorderStatus @default(PENDING)
  estimatedArrival DateTime?
  /// Si no paga el depósito en X días, la reserva expira
  expiresAt        DateTime?

  /// Pago del depósito — transferencia/WhatsApp manual
  depositStatus   PaymentStatus  @default(UNPAID)
  depositMethod   PaymentMethod?
  depositPaidAt   DateTime?
  depositProofUrl String?

  /// Cuando la reserva se convierte en pedido final
  orderId String? @unique
  order   Order?  @relation(fields: [orderId], references: [id])

  notes String? @db.Text

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  confirmedAt DateTime?
  cancelledAt DateTime?
  convertedAt DateTime?

  @@index([userId])
  @@index([productId])
  @@index([status])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Collections
// ---------------------------------------------------------------------------

model Collection {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  description String? @db.Text
  imageUrl    String?
  active      Boolean @default(true)

  products ProductCollection[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([slug])
  @@index([active])
}

model ProductCollection {
  productId    String
  collectionId String

  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([productId, collectionId])
  @@index([collectionId])
}

// ---------------------------------------------------------------------------
// Promotions
// ---------------------------------------------------------------------------

enum PromotionType {
  FREE_SHIPPING
  FIXED_DISCOUNT
  PERCENT_DISCOUNT
}

model Promotion {
  id          String        @id @default(cuid())
  name        String
  description String?       @db.Text
  type        PromotionType
  active      Boolean       @default(true)

  /// Monto mínimo de compra (en PEN) para activar la promoción
  minAmount       Decimal? @db.Decimal(10, 2)
  /// Descuento fijo en soles (para FIXED_DISCOUNT)
  discountAmount  Decimal? @db.Decimal(10, 2)
  /// Porcentaje de descuento 0-100 (para PERCENT_DISCOUNT)
  discountPercent Decimal? @db.Decimal(5, 2)

  startsAt DateTime?
  endsAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, active])
}

// ---------------------------------------------------------------------------
// Marketing
// ---------------------------------------------------------------------------

model Banner {
  id       String    @id @default(cuid())
  title    String
  subtitle String?
  imageUrl String
  ctaLabel String?
  ctaHref  String?
  position Int       @default(0)
  active   Boolean   @default(true)
  startsAt DateTime?
  endsAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, position])
}

// ---------------------------------------------------------------------------
// Contenido legal editable desde el admin (términos, políticas)
// ---------------------------------------------------------------------------

model LegalPage {
  id      String @id @default(cuid())
  slug    String @unique
  title   String
  content String @default("") @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// CTA del home (franja "Ediciones Limitadas") — editable desde el admin.
// Registro único con id fijo 'home-cta'.
// ---------------------------------------------------------------------------

model HomeCta {
  id       String  @id
  title    String
  subtitle String  @default("")
  ctaLabel String  @default("")
  ctaHref  String  @default("")
  imageUrl String  @default("")
  active   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Configuración general de la tienda — registro único con id 'store'
// ---------------------------------------------------------------------------

model StoreSettings {
  id             String  @id
  showOutOfStock Boolean @default(true)
  whatsappNumber String  @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Métodos de pago manuales mostrados en el checkout (Yape, BCP, BBVA, etc.)
// ---------------------------------------------------------------------------

model PaymentAccount {
  id       String  @id @default(cuid())
  name     String
  holder   String  @default("")
  number   String
  cci      String  @default("")
  position Int     @default(0)
  active   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, position])
}

// ---------------------------------------------------------------------------
// Alertas del admin — generadas por el cron /api/cron/alerts
// ---------------------------------------------------------------------------

enum AdminAlertType {
  LOW_STOCK
  PENDING_ORDERS
  PROMO_EXPIRING
  DAILY_SUMMARY
}

model AdminAlert {
  id      String         @id @default(cuid())
  type    AdminAlertType
  title   String
  message String         @db.Text
  readAt  DateTime?

  createdAt DateTime @default(now())

  @@index([readAt, createdAt])
}

// ---------------------------------------------------------------------------
// Libro de Reclamaciones Virtual — formato exigido por Indecopi (Perú,
// DS 011-2011-PCM). El cliente llena el formulario público sin necesidad de
// cuenta; el admin responde desde /admin/complaints dentro del plazo legal.
// ---------------------------------------------------------------------------

enum ComplaintType {
  RECLAMO
  QUEJA
}

enum ComplaintStatus {
  PENDING
  ANSWERED
}

model Complaint {
  id   String @id @default(cuid())
  code String @unique

  // Datos del consumidor reclamante
  fullName  String
  docType   String @default("DNI")
  docNumber String
  address   String
  phone     String
  email     String

  // Datos del bien contratado
  productDescription String   @db.Text
  claimedAmount      Decimal? @db.Decimal(10, 2)

  // Detalle de la reclamación
  type    ComplaintType
  detail  String        @db.Text
  request String        @db.Text

  // Gestión del proveedor (admin)
  status      ComplaintStatus @default(PENDING)
  response    String?         @db.Text
  respondedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
}
